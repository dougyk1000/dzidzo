{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string" },
        "class": { "type": "string" },
        "level": { "type": "string" },
        "syllabus": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "chatbotName": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "email", "name", "role", "onboardingComplete"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Stores school announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "author": { "type": "string" }
      },
      "required": ["title", "content", "timestamp", "author"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Stores educational resources",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "level": { "type": "string" },
        "url": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "type", "subject", "level", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "Stores chat messages",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "content": { "type": "string" },
        "role": { "type": "string" },
        "timestamp": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["uid", "content", "role", "timestamp"]
    },
    "Homework": {
      "title": "Homework",
      "description": "Stores homework assignments",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "level": { "type": "string" },
        "examBoard": { "type": "string" },
        "dueDate": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "subject", "level", "dueDate", "authorId", "authorName", "timestamp"]
    },
    "Progress": {
      "title": "Progress",
      "description": "Stores student progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "topic": { "type": "string" },
        "type": { "type": "string" },
        "lastAttempt": { "type": "string" },
        "weaknessLevel": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "subject", "score", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile collection"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Announcements collection"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Resources collection"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages collection"
    },
    "/homework/{homeworkId}": {
      "schema": "Homework",
      "description": "Homework collection"
    },
    "/progress/{progressId}": {
      "schema": "Progress",
      "description": "Progress collection"
    }
  }
}
